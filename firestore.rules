rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function autenticado() {
      return request.auth != null;
    }

    function esMiUsuario(uid) {
      return autenticado() && request.auth.uid == uid;
    }

    function docPareja(coupleId) {
      return get(/databases/$(database)/documents/couples/$(coupleId));
    }

    function docParejaPost(coupleId) {
      return getAfter(/databases/$(database)/documents/couples/$(coupleId));
    }

    function parejaExiste(coupleId) {
      return (
        coupleId is string
        && coupleId.size() > 0
        && exists(/databases/$(database)/documents/couples/$(coupleId))
      );
    }

    function parejaExistePost(coupleId) {
      return (
        coupleId is string
        && coupleId.size() > 0
        && existsAfter(/databases/$(database)/documents/couples/$(coupleId))
      );
    }

    function esMiPareja(coupleId) {
      return (
        autenticado()
        && parejaExiste(coupleId)
        && (
          docPareja(coupleId).data.user1Id == request.auth.uid
          || docPareja(coupleId).data.user2Id == request.auth.uid
        )
      );
    }

    function esMiParejaPost(coupleId) {
      return (
        autenticado()
        && parejaExistePost(coupleId)
        && (
          docParejaPost(coupleId).data.user1Id == request.auth.uid
          || docParejaPost(coupleId).data.user2Id == request.auth.uid
        )
      );
    }

    function user1Pareja(coupleId) {
      return docPareja(coupleId).data.user1Id;
    }

    function user2Pareja(coupleId) {
      return docPareja(coupleId).data.user2Id;
    }

    function esUidPareja(coupleId, uid) {
      return (
        uid is string
        && uid.size() > 0
        && (
          uid == user1Pareja(coupleId)
          || uid == user2Pareja(coupleId)
        )
      );
    }

    function docInvite(inviteCode) {
      return get(/databases/$(database)/documents/invite_codes/$(inviteCode));
    }

    function inviteActivoParaPareja(inviteCode, coupleId) {
      return (
        inviteCode is string
        && inviteCode.size() == 6
        && exists(/databases/$(database)/documents/invite_codes/$(inviteCode))
        && docInvite(inviteCode).data.coupleId == coupleId
        && docInvite(inviteCode).data.active == true
      );
    }

    function emocionValida(emocion) {
      return (
        emocion is map
        && emocion.keys().hasOnly(['mood', 'intensity', 'updatedAt'])
        && emocion.mood is string
        && emocion.intensity is number
        && emocion.updatedAt is int
      );
    }

    function cambiosParejaPermitidos() {
      return (
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'connectionStrength',
          'user1Emotion',
          'user2Emotion',
          'lastCheckinUser1',
          'lastCheckinUser2',
          'lastStreakDate',
          'streakDays'
        ])
        && request.resource.data.user1Id == resource.data.user1Id
        && request.resource.data.user2Id == resource.data.user2Id
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.universeState == resource.data.universeState
        && request.resource.data.connectionStrength is int
        && (
          !('user1Emotion' in request.resource.data)
          || emocionValida(request.resource.data.user1Emotion)
        )
        && (
          !('user2Emotion' in request.resource.data)
          || emocionValida(request.resource.data.user2Emotion)
        )
        && (
          !('lastCheckinUser1' in request.resource.data)
          || request.resource.data.lastCheckinUser1 is string
        )
        && (
          !('lastCheckinUser2' in request.resource.data)
          || request.resource.data.lastCheckinUser2 is string
        )
        && (
          !('lastStreakDate' in request.resource.data)
          || request.resource.data.lastStreakDate is string
        )
        && (
          !('streakDays' in request.resource.data)
          || request.resource.data.streakDays is int
        )
      );
    }

    function cambioJoinParejaPermitido(coupleId) {
      return (
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['user2Id'])
        && resource.data.user2Id == ''
        && request.resource.data.user2Id == request.auth.uid
        && request.auth.uid != resource.data.user1Id
        && inviteActivoParaPareja(resource.data.inviteCode, coupleId)
      );
    }

    function claveRespuesta(uid) {
      return 'answer_' + uid;
    }

    function claveGratitud(uid) {
      return 'gratitude_' + uid;
    }

    function claveSyncHolding(uid) {
      return 'syncHolding_' + uid;
    }

    function claveSyncHoldSince(uid) {
      return 'syncHoldSince_' + uid;
    }

    function clavesRitualPermitidas(coupleId) {
      return [
        'question',
        'completedBy',
        'updatedAt',
        'syncInviteFrom',
        'syncInviteAt',
        'syncUpdatedAt',
        'syncCompleted',
        'syncCompletedAt',
        'syncEvent',
        claveRespuesta(user1Pareja(coupleId)),
        claveRespuesta(user2Pareja(coupleId)),
        claveGratitud(user1Pareja(coupleId)),
        claveGratitud(user2Pareja(coupleId)),
        claveSyncHolding(user1Pareja(coupleId)),
        claveSyncHolding(user2Pareja(coupleId)),
        claveSyncHoldSince(user1Pareja(coupleId)),
        claveSyncHoldSince(user2Pareja(coupleId))
      ];
    }

    function listaGratitudValida(valor) {
      return valor is list && valor.size() <= 8;
    }

    function ritualPayloadValido(coupleId, data) {
      return (
        data.keys().hasOnly(clavesRitualPermitidas(coupleId))
        && (
          !('question' in data)
          || data.question is string
        )
        && (
          !('completedBy' in data)
          || (
            data.completedBy is list
            && data.completedBy.hasOnly([user1Pareja(coupleId), user2Pareja(coupleId)])
          )
        )
        && (
          !('updatedAt' in data)
          || data.updatedAt is int
        )
        && (
          !('syncInviteFrom' in data)
          || esUidPareja(coupleId, data.syncInviteFrom)
        )
        && (
          !('syncInviteAt' in data)
          || data.syncInviteAt is int
        )
        && (
          !('syncUpdatedAt' in data)
          || data.syncUpdatedAt is int
        )
        && (
          !('syncCompleted' in data)
          || data.syncCompleted is bool
        )
        && (
          !('syncCompletedAt' in data)
          || data.syncCompletedAt is int
        )
        && (
          !('syncEvent' in data)
          || data.syncEvent is string
        )
        && (
          !(claveRespuesta(user1Pareja(coupleId)) in data)
          || data[claveRespuesta(user1Pareja(coupleId))] is string
        )
        && (
          !(claveRespuesta(user2Pareja(coupleId)) in data)
          || data[claveRespuesta(user2Pareja(coupleId))] is string
        )
        && (
          !(claveGratitud(user1Pareja(coupleId)) in data)
          || listaGratitudValida(data[claveGratitud(user1Pareja(coupleId))])
        )
        && (
          !(claveGratitud(user2Pareja(coupleId)) in data)
          || listaGratitudValida(data[claveGratitud(user2Pareja(coupleId))])
        )
        && (
          !(claveSyncHolding(user1Pareja(coupleId)) in data)
          || data[claveSyncHolding(user1Pareja(coupleId))] is bool
        )
        && (
          !(claveSyncHolding(user2Pareja(coupleId)) in data)
          || data[claveSyncHolding(user2Pareja(coupleId))] is bool
        )
        && (
          !(claveSyncHoldSince(user1Pareja(coupleId)) in data)
          || data[claveSyncHoldSince(user1Pareja(coupleId))] is int
        )
        && (
          !(claveSyncHoldSince(user2Pareja(coupleId)) in data)
          || data[claveSyncHoldSince(user2Pareja(coupleId))] is int
        )
      );
    }

    match /users/{uid} {
      allow read: if esMiUsuario(uid);

      allow create: if esMiUsuario(uid)
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'coupleId',
          'createdAt',
          'lastSeen',
          'fcmToken'
        ])
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.createdAt is int
        && (
          !('coupleId' in request.resource.data)
          || request.resource.data.coupleId == ''
        )
        && (!('lastSeen' in request.resource.data) || request.resource.data.lastSeen is int);

      allow update: if esMiUsuario(uid)
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'coupleId',
          'createdAt',
          'lastSeen',
          'fcmToken'
        ])
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.createdAt is int
        && (!('lastSeen' in request.resource.data) || request.resource.data.lastSeen is int)
        && (
          !('coupleId' in request.resource.data)
          || (
            ('coupleId' in resource.data)
            && request.resource.data.coupleId == resource.data.coupleId
          )
          || request.resource.data.coupleId == ''
          || esMiPareja(request.resource.data.coupleId)
          || esMiParejaPost(request.resource.data.coupleId)
        );

      allow delete: if false;
    }

    match /invite_codes/{inviteCode} {
      allow get: if autenticado();
      allow list: if false;

      allow create: if autenticado()
        && inviteCode is string
        && inviteCode.matches('^[A-Z0-9]{6}$')
        && request.resource.data.keys().hasOnly([
          'coupleId',
          'createdBy',
          'createdAt',
          'active'
        ])
        && request.resource.data.coupleId is string
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is int
        && request.resource.data.active == true
        && parejaExistePost(request.resource.data.coupleId)
        && docParejaPost(request.resource.data.coupleId).data.user1Id == request.auth.uid
        && docParejaPost(request.resource.data.coupleId).data.user2Id == ''
        && docParejaPost(request.resource.data.coupleId).data.inviteCode == inviteCode;

      allow update: if autenticado()
        && resource.data.coupleId is string
        && (
          esMiPareja(resource.data.coupleId)
          || esMiParejaPost(resource.data.coupleId)
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['active'])
        && request.resource.data.coupleId == resource.data.coupleId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && resource.data.active == true
        && request.resource.data.active == false;

      allow delete: if false;
    }

    match /couples/{coupleId} {
      allow get: if esMiPareja(coupleId);
      allow list: if false;

      allow create: if autenticado()
        && request.resource.data.keys().hasOnly([
          'user1Id',
          'user2Id',
          'inviteCode',
          'createdAt',
          'connectionStrength',
          'universeState'
        ])
        && request.resource.data.user1Id == request.auth.uid
        && request.resource.data.user2Id == ''
        && request.resource.data.inviteCode is string
        && request.resource.data.inviteCode.size() == 6
        && request.resource.data.createdAt is int
        && request.resource.data.connectionStrength is int
        && request.resource.data.universeState is map;

      allow update: if autenticado() && (
        (
          esMiPareja(coupleId)
          && cambiosParejaPermitidos()
        )
        ||
        cambioJoinParejaPermitido(coupleId)
      );

      allow delete: if false;
    }

    match /memories/{memoryId} {
      allow read: if esMiPareja(resource.data.coupleId);

      allow create: if esMiPareja(request.resource.data.coupleId)
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.createdAt is int
        && request.resource.data.posX is number
        && request.resource.data.posY is number
        && (
          !('createdByUserId' in request.resource.data) ||
          request.resource.data.createdByUserId == request.auth.uid ||
          request.resource.data.createdByUserId == 'system'
        );

      allow update, delete: if false;
    }

    match /goals/{goalId} {
      allow read: if esMiPareja(resource.data.coupleId);

      allow create: if esMiPareja(request.resource.data.coupleId)
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.targetDate is int
        && request.resource.data.progress is number
        && request.resource.data.progress >= 0
        && request.resource.data.progress <= 1
        && request.resource.data.createdAt is int;

      allow update: if esMiPareja(resource.data.coupleId)
        && request.resource.data.coupleId == resource.data.coupleId
        && request.resource.data.title == resource.data.title
        && request.resource.data.description == resource.data.description
        && request.resource.data.targetDate == resource.data.targetDate
        && request.resource.data.symbol == resource.data.symbol
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.progress is number
        && request.resource.data.progress >= 0
        && request.resource.data.progress <= 1
        && (
          !('completedAt' in request.resource.data) ||
          request.resource.data.completedAt == null ||
          request.resource.data.completedAt is int
        );

      allow delete: if false;
    }

    match /capsules/{capsuleId} {
      allow read: if esMiPareja(resource.data.coupleId);

      allow create: if esMiPareja(request.resource.data.coupleId)
        && request.resource.data.createdByUserId == request.auth.uid
        && request.resource.data.createdAt is int
        && request.resource.data.unlockAt is int
        && request.resource.data.openedByUserIds is list;

      allow update: if esMiPareja(resource.data.coupleId)
        && request.resource.data.coupleId == resource.data.coupleId
        && request.resource.data.title == resource.data.title
        && request.resource.data.message == resource.data.message
        && request.resource.data.createdByUserId == resource.data.createdByUserId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.unlockAt == resource.data.unlockAt
        && request.resource.data.openedByUserIds is list
        && request.resource.data.openedByUserIds.hasAll(resource.data.openedByUserIds)
        && request.resource.data.openedByUserIds.hasAny([request.auth.uid])
        && request.resource.data.openedByUserIds.size() <= resource.data.openedByUserIds.size() + 1;

      allow delete: if false;
    }

    match /daily_questions/{docId} {
      allow read: if esMiPareja(resource.data.coupleId);

      allow create: if esMiPareja(request.resource.data.coupleId)
        && request.resource.data.dayKey is string
        && request.resource.data.question is string
        && request.resource.data.answers is map
        && request.resource.data.createdAt is int
        && (
          !('revealedAt' in request.resource.data) ||
          request.resource.data.revealedAt == null ||
          request.resource.data.revealedAt is int
        );

      allow update: if esMiPareja(resource.data.coupleId)
        && request.resource.data.coupleId == resource.data.coupleId
        && request.resource.data.dayKey == resource.data.dayKey
        && request.resource.data.question == resource.data.question
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.answers is map
        && request.resource.data.answers.diff(resource.data.answers).changedKeys().hasOnly([request.auth.uid])
        && request.resource.data.answers[request.auth.uid] is string
        && request.resource.data.answers.size() <= 2
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['answers', 'revealedAt'])
        && (
          !('revealedAt' in request.resource.data) ||
          request.resource.data.revealedAt == resource.data.revealedAt ||
          (
            request.resource.data.revealedAt is int
            && request.resource.data.answers.size() >= 2
          )
        );

      allow delete: if false;
    }

    match /wishes/{wishId} {
      allow read: if esMiPareja(resource.data.coupleId);

      allow create: if esMiPareja(request.resource.data.coupleId)
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.createdAt is int
        && request.resource.data.seen == false;

      allow update: if esMiPareja(resource.data.coupleId)
        && request.resource.data.coupleId == resource.data.coupleId
        && request.resource.data.id == resource.data.id
        && request.resource.data.message == resource.data.message
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.seen == true
        && resource.data.fromUserId != request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['seen']);

      allow delete: if false;
    }

    match /rituals/{coupleId}/weekly/{weekId} {
      allow read: if esMiPareja(coupleId);

      allow create: if esMiPareja(coupleId)
        && ritualPayloadValido(coupleId, request.resource.data);

      allow update: if esMiPareja(coupleId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(clavesRitualPermitidas(coupleId))
        && ritualPayloadValido(coupleId, request.resource.data);

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
