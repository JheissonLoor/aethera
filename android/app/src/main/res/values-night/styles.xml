<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Deep space background color matching AetheraTokens.deepSpace -->
    <color name="deepSpace">#070B14</color>

    <!-- Theme while the process is starting (dark mode) -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Theme applied once Flutter engine starts -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/deepSpace</item>
        <item name="android:windowFullscreen">false</item>
    </style>
</resources>
